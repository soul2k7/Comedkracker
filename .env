# ─────────────────────────────────────────
#  COMEDKracker — Environment Variables
# ─────────────────────────────────────────
#  Rename this file to  .env  and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────

# Gmail account you'll send FROM
# e.g.  comedkracker@gmail.com
EMAIL_USER=comedkracker@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# How to get it:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → Generate one for "Mail"
#   4. Paste the 16-character code below
EMAIL_PASS=kdfe rcvz hysw cvux

# Email address where you want to RECEIVE enquiries
# Can be the same as EMAIL_USER, or a different address
RECEIVER_EMAIL=comedkracker@gmail.com

# Port the server listens on (3000 is fine for local dev)
PORT=3000
